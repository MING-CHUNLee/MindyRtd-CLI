# ==================================
# Mindy RStudio CLI — Local Config
# ==================================
# DO NOT commit this file. It is listed in .gitignore.

# ==================================
# Ruby Backend API
# ==================================
# The Ruby API server that proxies calls to the LLM (run with: rake run)
API_HOST=localhost
API_PORT=9090

# ==================================
# LLM Provider Configuration
# ==================================
# The Ruby API server (rake run) that proxies calls to the LLM.
API_HOST=localhost
API_PORT=9090

# ==================================
# LLM Provider (direct access, optional)
# ==================================
# Only needed if you call the LLM directly from the CLI (not via Ruby API).
LLM_PROVIDER=google
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-your-openai-key-here
GEMINI_API_KEY=your-google-gemini-api-key-here

# ==================================
# Model Configuration (optional)
# ==================================
# LLM_MODEL=claude-sonnet-4-20250514
# LLM_MAX_TOKENS=4096
# LLM_TIMEOUT=60000

# ==================================
# Debug
# ==================================
# DEBUG=false
# LOG_LEVEL=info
