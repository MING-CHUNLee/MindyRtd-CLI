# ==================================
# Mindy RStudio CLI — Local Config
# ==================================
# DO NOT commit this file. It is listed in .gitignore.

# ==================================
# Ruby Backend API (LLM proxy)
# ==================================
# The Ruby API server that proxies calls to the LLM (run with: rake run)
API_HOST=localhost
API_PORT=9090

# ==================================
# Tyla API Backend
# ==================================
# The Tyla Rails/Roda API server (prompt logs, analytics)
TYLA_API_HOST=localhost
TYLA_API_PORT=9292

# ==================================
# LLM Provider Configuration
# ==================================
# The Ruby API server (rake run) that proxies calls to the LLM.
API_HOST=localhost
API_PORT=9090

# ==================================
# LLM Provider (direct access, optional)
# ==================================
# Only needed if you call the LLM directly from the CLI (not via Ruby API).
LLM_PROVIDER=openai

# ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-your-openai-key-here
GEMINI_API_KEY=your-google-gemini-api-key-here


LLM_MODEL=gpt-4o

# 貼上你剛剛申請的 GitHub PAT (for GitHub Models)
OPENAI_API_KEY=
# GitHub Models 使用 OpenAI 相容 API，但 endpoint 不同，需加下面這行：
OPENAI_API_BASE=https://models.inference.ai.azure.com/chat/completions


# ==================================
# Model Configuration (optional)
# ==================================
# LLM_MODEL=claude-sonnet-4-20250514
# LLM_MAX_TOKENS=4096
# LLM_TIMEOUT=60000

# ==================================
# Acceptance Test Recording
# ==================================
# Controls how BDD acceptance tests (tests/acceptance/) source LLM responses.
#
#   (unset / inline)  — hand-crafted cassettes, no API key needed (default)
#   record            — real LLM calls; cassettes saved to fixtures/*.json
#   replay-file       — replay from fixtures/*.json saved by record mode
#
# To re-record cassettes for ask + run pipelines:
#   macOS/Linux:  ACCEPTANCE_TEST_MODE=record bun test tests/acceptance/ask-pipeline.test.ts
#   Windows PS:   $env:ACCEPTANCE_TEST_MODE="record"; bun test tests/acceptance/ask-pipeline.test.ts
#   Windows (alt): set ACCEPTANCE_TEST_MODE=record in this .env file, run bun test, then remove it
#
# Note: edit-pipeline cassettes are hand-crafted (see that file for details).
ACCEPTANCE_TEST_MODE=replay-file

# ==================================
# Debug
# ==================================
# DEBUG=false
# LOG_LEVEL=info
